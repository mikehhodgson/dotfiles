#!/usr/bin/env bash

set -euo pipefail

# Check that at least one argument was supplied
if [ "$#" -eq 0 ]; then
    echo "Usage: $(basename "$0") EVENT_NAME"
    exit 1
fi

if ! gphoto2 --summary >/dev/null 2>&1; then
    echo "No camera detected."
    exit 1
fi

eventname="$*"

cd "$HOME/Pictures/Photography"

year=$(date +%Y)

# Create year folder if it doesn't exist
mkdir -p "$year"

cd "$year"

foldername="$(date --iso-8601=date) ${eventname}"

# Refuse to overwrite an existing event
if [ -d "$foldername" ]; then
    if [ -z "$(ls -A "$foldername")" ]; then
        echo "Warning: Existing empty folder found, resuming."
    else
        echo "Error: Event folder already exists and is not empty:"
        echo "  $PWD/$foldername"
        exit 1
    fi
else
    mkdir "$foldername"
fi


cd "$foldername"

gphoto2 --get-all-files

# If you want to avoid accidentally downloading the same photos again on future runs, consider:
# gphoto2 --get-all-files --skip-existing

# or, if you want the photos removed from the camera after a successful download:
# gphoto2 --get-all-files --delete-after
